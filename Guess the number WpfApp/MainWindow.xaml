<Window x:Class="Guess_the_number_WpfApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Guess_the_number_WpfApp"
        mc:Ignorable="d"
        Title="Guess the number" Height="300" Width="500">
    <Grid>
        <StackPanel Margin="20">
            <TextBlock Name="HintTextBlock" FontSize="20" TextAlignment="Center"/>

            <TextBox Name="GuessTextBox" Margin="0,10" />

            <TextBlock Name="AttemptsTextBlock"/>

            <Button Name="CheckButton" Content="Проверить"  Margin="5" Click="CheckButton_Click"
                    Width="200" Height="30" FontSize="20"/>

            <Button Name="NewGameButton" Content="Новая игра" Margin="5" Click="NewGameButton_Click"
                    Width="200" Height="30" FontSize="20"/>
        </StackPanel>
    </Grid>
</Window>
